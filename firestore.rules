rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // === 1. FONCTIONS UTILITAIRES ===
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Role verification via token custom claims (preferable) or document read
    function isAdmin() {
      return isAuthenticated() && (
        ("admin" in request.auth.token && request.auth.token.admin == true) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isInstructor() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    // === 2. VERROUILLAGE PAR DEFAUT ===
    match /{document=**} {
      allow read, write: if false;
    }

    // === 3. UTILISATEURS (users) ===
    match /users/{userId} {
      allow read: if isAuthenticated(); // Profils publics lisibles
      
      // Sécurité Anti-Escalade: interdit de modifier 'role', 'walletBalance', 'isAdmin', 'isPremium'
      allow create: if isOwner(userId) 
        && (!request.resource.data.keys().hasAny(['role', 'walletBalance', 'isAdmin', 'isPremium']) || request.resource.data.role == 'student');
        
      allow update: if isAdmin() || (isOwner(userId) 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'walletBalance', 'isAdmin', 'isPremium']));
        
      allow delete: if isAdmin();

      // Sous-collections privées (Notifications, Panier, etc.)
      match /notifications/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /cart/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /mathias_chats/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // === 4. FINANCES & TRANSACTIONS (BACKEND UNIQUEMENT EN ECRITURE) ===
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // L'écriture est STRICTEMENT réservée au Cloud Backend (SDK Admin bypass cette règle)
      allow write: if false; 
    }
    
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Géré par le serveur Stripe/API
    }

    match /wallets/{walletId} {
      allow read: if isAuthenticated() && (walletId == request.auth.uid || isAdmin());
      allow write: if false;
    }
    
    match /payout_requests/{payoutId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.instructorId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isAdmin(); // Le paiement réel est traité par l'Admin via Backend
    }

    // === 5. COURS (courses) ===
    match /courses/{courseId} {
      allow read: if resource.data.status == 'Published' || isAdmin() || (isAuthenticated() && resource.data.instructorId == request.auth.uid);
      
      // Autorise les créateurs, mais sécurise la propriété
      allow create: if isAuthenticated() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() 
        && resource.data.instructorId == request.auth.uid 
        && request.resource.data.instructorId == request.auth.uid); // Empêche de changer le créateur
        
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.instructorId == request.auth.uid);

      // Sous-collections de cours
      match /quizzes/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
      match /assignments/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
    }

    // === 6. ENROLLMENTS (Inscriptions) ===
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      
      // La création initiale (paiement du cours) DOIT être faite par le backend.
      allow create: if false; 
      
      // Les étudiants ne peuvent modifier que leur progression
      allow update: if isAdmin() || (isAuthenticated() 
        && resource.data.studentId == request.auth.uid 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'lastAccessedAt', 'completedModules']));
        
      allow delete: if isAdmin();
    }

    // === 7. DEVOIRS (Soumissions) ===
    match /devoirs/{devoirId} {
      // Lecture: étudiant ou instructeur concerné du cours
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      
      // Création: l'étudiant soumet son devoir
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        // Etudiant: modifie son devoir mais PAS la note/le retour instructeur
        (resource.data.studentId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['grade', 'feedback'])) 
        ||
        // Instructeur: ne peut modifier QUE la note, le feedback et le statut
        (resource.data.instructorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['grade', 'feedback', 'status']))
        || isAdmin()
      );
      
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
    }

    // === 8. QUIZ SUBMISSIONS ===
    match /quiz_submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      // Les notes de quiz automatisées sont gérées par le calcul client + validation backend eventuelle
      allow update: if isAdmin() || resource.data.studentId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // === 9. MESSAGERIE / CHATS ===
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants) || isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAdmin() || (isAuthenticated() && (request.auth.uid in resource.data.participants) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime']));
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && (request.auth.uid in request.resource.data.participants);
      allow update, delete: if isAdmin();
    }

    // === 10. SYSTEME ET CONFIG ===
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /marketing_campaigns/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
