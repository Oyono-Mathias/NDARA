rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règle de base par défaut : aucune permission
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Rôle Administrateur
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 2. Sécurisation des Collections Admin
    
    // Paramètres globaux (settings)
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // Télémétrie et Sécurité (logs)
    match /system_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /security_audit_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Moteur Marketing
    match /marketing_campaigns/{docId} {
      allow read, write: if isAdmin();
    }
    match /email_templates/{docId} {
      allow read, write: if isAdmin();
    }

    // Retraits (payouts)
    match /payouts/{docId} {
      // Lecture et modification du statut réservées aux admins
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
      // Les instructeurs/utilisateurs peuvent uniquement créer une demande de retrait
      allow create: if request.auth != null;
    }

    // 3. Sécurisation des Collections Métier

    // Utilisateurs (users)
    match /users/{userId} {
      // Tout utilisateur authentifié peut lire son propre profil, les admins peuvent tout lire
      allow read: if isOwner(userId) || isAdmin();
      // Création de profil pour tous les nouveaux inscrits
      allow create: if isOwner(userId) || isAdmin();
      // Un utilisateur peut modifier son profil, sauf pour s'élever en admin ou se débannir
      allow update: if isAdmin() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBanned', 'status'])
      );
      // Seuls les admins peuvent bannir / supprimer (ou modifier les rôles avec full accès en update)
      allow delete: if isAdmin();
    }

    // Cours (courses)
    match /courses/{courseId} {
      // Lecture publique pour les cours publiés
      allow read: if (resource.data.status == 'Published') || isAdmin() || (request.auth != null && resource.data.instructorId == request.auth.uid);
      // Création autorisée pour les instructeurs propriétaires
      allow create: if request.auth != null;
      // Modification autorisée pour le propriétaire, MAIS seul l'admin peut modifier le statut d'arbitrage (ex: publier)
      allow update: if isAdmin() || (
        request.auth != null && 
        resource.data.instructorId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'arbitrationStatus'])
      );
      allow delete: if isAdmin() || (request.auth != null && resource.data.instructorId == request.auth.uid);
    }

    // Support (support_tickets)
    match /support_tickets/{ticketId} {
      // Un utilisateur peut créer ses propres tickets
      // (On assume que le userId est attaché au document existant et entrant)
      allow create: if request.auth != null 
        && (request.resource.data.userId == request.auth.uid || !('userId' in request.resource.data));
      // Un utilisateur peut voir ses propres tickets
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      // Les admins ont un accès total en écriture
      allow update, delete: if isAdmin();
    }

    // Base de connaissance (faq_entries)
    match /faq_entries/{faqId} {
      // Lecture publique pour les utilisateurs (et l'IA)
      allow read: if true;
      // Écriture strictement réservée aux admins
      allow write: if isAdmin();
    }

    // Raccourcis complémentaires métier essentiels au bon fonctionnement du dashboard
    match /payments/{docId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }
  }
}
