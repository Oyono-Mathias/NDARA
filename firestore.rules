rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // === 1. FONCTIONS UTILITAIRES ===
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        ("admin" in request.auth.token && request.auth.token.admin == true) || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ceo'
          )
        )
      );
    }
    
    function isInstructor() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    // === 2. VERROUILLAGE PAR DEFAUT ===
    match /{document=**} {
      allow read, write: if false;
    }

    // === 3. UTILISATEURS (users) ===
    match /users/{userId} {
      allow read: if true; // Profils publics lisibles par tous pour les invitations et leaderboards
      
      // Sécurité Anti-Escalade: interdit de modifier 'walletBalance', 'isAdmin', 'isPremium'. Modif 'role' autorisée uniquement pour passer 'pending_instructor'
      allow create: if isOwner(userId) 
        && (!request.resource.data.keys().hasAny(['role', 'walletBalance', 'isAdmin', 'isPremium']) || request.resource.data.role == 'student');
        
      allow update: if isAdmin() || (isOwner(userId) 
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['walletBalance', 'isAdmin', 'isPremium'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || (resource.data.role == 'student' && request.resource.data.role == 'pending_instructor')));
        
      allow delete: if isAdmin();

      // Sous-collections privées (Notifications, Panier, etc.)
      match /notifications/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /cart/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /mathias_chats/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // === 4. FINANCES & TRANSACTIONS (BACKEND UNIQUEMENT EN ECRITURE) ===
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // L'écriture est STRICTEMENT réservée au Cloud Backend (SDK Admin bypass cette règle)
      allow write: if false; 
    }
    
    match /payments/{paymentId} {
      allow read: if isAdmin() 
        || (isAuthenticated() && "instructorId" in resource.data && resource.data.instructorId == request.auth.uid) 
        || (isAuthenticated() && "userId" in resource.data && resource.data.userId == request.auth.uid);
      allow write: if false; // Géré par le serveur Stripe/API
    }

    match /wallets/{walletId} {
      allow read: if isAuthenticated() && (walletId == request.auth.uid || isAdmin());
      allow write: if false;
    }
    
    match /payout_requests/{payoutId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.instructorId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isAdmin(); // Le paiement réel est traité par l'Admin via Backend
    }

    // === 5. COURS (courses) ===
    match /courses/{courseId} {
      allow read: if isAdmin() || resource.data.status == 'Published' || (isAuthenticated() && resource.data.instructorId == request.auth.uid);
      
      // Autorise les créateurs, mais sécurise la propriété
      allow create: if isAuthenticated() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() 
        && resource.data.instructorId == request.auth.uid 
        && request.resource.data.instructorId == request.auth.uid); // Empêche de changer le créateur
        
      allow delete: if isAdmin() || (isAuthenticated() && (!("instructorId" in resource.data) || resource.data.instructorId == request.auth.uid || resource.data.instructorId == null));

      // Sous-collections de cours
      match /quizzes/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
      match /assignments/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
    }

    // === 6. ENROLLMENTS (Inscriptions) ===
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() 
        || (isAuthenticated() && 'studentId' in resource.data && resource.data.studentId == request.auth.uid) 
        || (isAuthenticated() && 'instructorId' in resource.data && resource.data.instructorId == request.auth.uid);
      
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid; 
      
      // Les étudiants ne peuvent modifier que leur progression
      allow update: if isAdmin() || (isAuthenticated() 
        && 'studentId' in resource.data
        && resource.data.studentId == request.auth.uid 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'lastAccessedAt', 'completedModules', 'completedLessons', 'isEligibleForCertificate', 'completedAt']));
        
      allow delete: if isAdmin();
    }

    // === 7. DEVOIRS (Soumissions) ===
    match /assignments_submissions/{devoirId} {
      // Lecture: étudiant ou instructeur concerné du cours
      allow read: if isAuthenticated() && (
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid) || 
        ('instructorId' in resource.data && resource.data.instructorId == request.auth.uid) || 
        isAdmin()
      );
      
      // Création: l'étudiant soumet son devoir
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        // Etudiant: modifie son devoir mais PAS la note/le retour instructeur
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['grade', 'feedback'])) 
        ||
        // Instructeur: ne peut modifier QUE la note, le feedback et le statut
        ('instructorId' in resource.data && resource.data.instructorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['grade', 'feedback', 'status']))
        || isAdmin()
      );
      
      allow delete: if isAuthenticated() && 'studentId' in resource.data && resource.data.studentId == request.auth.uid;
    }

    // === 8. QUIZ SUBMISSIONS ===
    match /quiz_results/{submissionId} {
      allow read: if isAuthenticated() && (
        ('studentId' in resource.data && resource.data.studentId == request.auth.uid) || 
        ('instructorId' in resource.data && resource.data.instructorId == request.auth.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      // Les notes de quiz automatisées sont gérées par le calcul client + validation backend eventuelle
      allow update: if isAdmin() || ('studentId' in resource.data && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // === 9. MESSAGERIE / CHATS ===
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants) || isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAdmin() || (isAuthenticated() && (request.auth.uid in resource.data.participants));
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only backend writes to stats
    }

    // === 10. SYSTEME ET CONFIG ===
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // === 11. ANNONCES ET MARKETING ===
    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /course_announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isInstructor() || isAdmin();
    }
    match /course_qna/{docId} {
      allow read: if isAuthenticated();
      allow write: if isInstructor() || isAuthenticated() || isAdmin();
    }
    match /course_questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isInstructor() || isAuthenticated() || isAdmin();
    }
    match /course_resources/{docId} {
      allow read: if isAuthenticated();
      allow write: if isInstructor() || isAdmin();
    }
    match /course_coupons/{docId} {
      allow read: if isAuthenticated();
      allow write: if isInstructor() || isAdmin();
    }
    match /squads/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /marketing_campaigns/{docId} {
      allow read, write: if isAdmin();
    }
    match /email_templates/{docId} {
      allow read, write: if isAdmin();
    }
    match /moderation_queue/{docId} {
      allow read, write: if isAdmin();
    }
    match /security_audit_logs/{docId} {
      allow read, write: if isAdmin();
    }
    match /market_templates/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /market_orders/{docId} {
      allow read: if isAuthenticated() && (resource.data == null || resource.data.buyerId == request.auth.uid || isAdmin());
      allow write: if isAdmin() || isAuthenticated();
    }
    match /market_items/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /promo_codes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /progress/{docId} {
      allow read, write: if isAuthenticated() && (resource.data.studentId == request.auth.uid || request.resource.data.studentId == request.auth.uid || isAdmin());
    }
    match /badges/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /system_logs/{docId} {
      allow read, write: if isAdmin();
    }
    match /support_tickets/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /faq_entries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /payouts/{docId} {
      allow read, write: if isAdmin();
    }
    match /market_ebooks/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /course_reviews/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /{path=**}/assignments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor');
    }
    match /{path=**}/quizzes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor');
    }
    match /{path=**}/questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor');
    }
    match /licenses/{docId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow write: if isAdmin() || isAuthenticated();
    }
    match /market_data/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /user_wishlist/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    match /user_history/{docId} {
      allow read: if isAuthenticated() && (('userId' in resource.data && resource.data.userId == request.auth.uid) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 'userId' in resource.data && resource.data.userId == request.auth.uid;
    }
    match /course_notes/{docId} {
      allow read: if isAuthenticated() && (('studentId' in resource.data && resource.data.studentId == request.auth.uid) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 'studentId' in resource.data && resource.data.studentId == request.auth.uid;
    }
    match /student_badges/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /purchases/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin() || isAuthenticated();
    }
    match /certificates/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.instructorId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /reports/{docId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
    }
    match /squad_messages/{docId} {
      allow read: if isAuthenticated(); // simplify, or check squad membership if available
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /user_follows/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }
  }
}
